# Telegram
TELEGRAM_BOT_TOKEN=123456:your-bot-token-here
# 逗號分隔的管理員 Telegram user id（可使用 /pending 等管理指令；自動納入白名單）
ADMIN_IDS=
# 白名單：逗號分隔的 Telegram user id，只有名單內的人能使用機器人。
# 若此項與 ADMIN_IDS 皆留空 → 開放模式（任何人皆可使用）。
# 不知道自己的 user id？對 @userinfobot 傳訊息即可查到。
ALLOWED_USER_IDS=

# 資料庫 / Redis（docker-compose 內部主機名）
DATABASE_URL=postgresql+psycopg://buytrack:buytrack@postgres:5432/buytrack
REDIS_URL=redis://redis:6379/0

# 反爬：逗號分隔的 proxy（http://user:pass@host:port），留空表示不使用
PROXY_POOL=

# 輪詢設定
DEFAULT_CHECK_INTERVAL_SEC=3600
# 每個網域兩次請求之間的最小間隔（秒），含 jitter
MIN_DOMAIN_INTERVAL_SEC=8
# 連續失敗達此次數才告警/暫停
MAX_CONSECUTIVE_FAILURES=5
# Beat 掃描到期商品的週期（秒）
ENQUEUE_PERIOD_SEC=60
